{
  "name": "svn-client",
  "version": "1.0.0",
  "description": "SVN Client for macOS",
  "main": "dist/src/main/main.js",
  "scripts": {
    "dev:renderer": "vite --config vite.config.ts",
    "dev:main": "tsc -p tsconfig.json && NODE_ENV=development electron .",
    "dev": "npm run build:main && concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5173 && npm run dev:main\"",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "vite build --config vite.config.ts",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --mac"
  },
  "keywords": ["svn", "subversion", "client"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.svn-client.app",
    "productName": "SVN Client",
    "mac": {
      "target": "dmg",
      "icon": null
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.11",
    "diff2html": "^3.4.56",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
